<ui:FluentWindow x:Class="WindowMusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Music Player"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None"
        Background="#FFFFFF">

    <ui:FluentWindow.Resources>
        <DrawingImage x:Key="AppIcon">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="Transparent">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,24,24"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen><Pen Brush="#680070" Thickness="2"/></GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="12,12" RadiusX="10" RadiusY="10"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#680070" Thickness="2" StartLineCap="Round" EndLineCap="Round"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M6,12 c0,-1.7,0.7,-3.2,1.8,-4.2"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen><Pen Brush="#680070" Thickness="2"/></GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="12,12" RadiusX="2" RadiusY="2"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#680070" Thickness="2" StartLineCap="Round" EndLineCap="Round"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M18,12 c0,1.7,-0.7,3.2,-1.8,4.2"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>

        <ControlTemplate x:Key="ProgressSliderTemplate" TargetType="Slider">
            <Grid VerticalAlignment="Center" MinHeight="22">
                <Track x:Name="PART_Track">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Focusable="False" IsTabStop="False" Cursor="Hand">
                            <RepeatButton.Template>
                                <ControlTemplate TargetType="RepeatButton">
                                    <Border Background="#680070" Height="4" CornerRadius="2,0,0,2"/>
                                </ControlTemplate>
                            </RepeatButton.Template>
                        </RepeatButton>
                    </Track.DecreaseRepeatButton>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Focusable="False" IsTabStop="False" Cursor="Hand">
                            <RepeatButton.Template>
                                <ControlTemplate TargetType="RepeatButton">
                                    <Border x:Name="Bd" Background="#E5E7EB" Height="4" CornerRadius="0,2,2,0"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#CBD5E1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RepeatButton.Template>
                        </RepeatButton>
                    </Track.IncreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Focusable="False" Width="14" Height="14" Cursor="Hand">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Ellipse Fill="White" Stroke="#680070" StrokeThickness="2.5"/>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style x:Key="SongRowStyle" TargetType="ListViewItem">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#F3F4F6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#680070"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <GridViewRowPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FDF5FE"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F5E5F7"/>
                                <Setter Property="Foreground" Value="#680070"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="Transparent"
                                BorderBrush="#E5E7EB"
                                BorderThickness="0,0,0,1"
                                Padding="16,10">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       FontSize="{TemplateBinding FontSize}"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerCtrlBtn" TargetType="{x:Type ui:Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#680070"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ui:Button}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F5E5F7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#DDB0DF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Music Player">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="{StaticResource AppIcon}"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="24,12,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                <ui:Button DockPanel.Dock="Right" Name="BtnOpenFolder" Click="BtnOpenFolder_Click"
                           Appearance="Secondary" VerticalAlignment="Center" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="FolderAdd20" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Add folder"/>
                    </StackPanel>
                </ui:Button>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="34" Height="34" Margin="0,0,12,0" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Ellipse Canvas.Left="2" Canvas.Top="2" Width="20" Height="20"
                                     Stroke="#680070" StrokeThickness="2" Fill="Transparent"/>
                            <Path Stroke="#680070" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M6,12 c0,-1.7,0.7,-3.2,1.8,-4.2"/>
                            <Ellipse Canvas.Left="10" Canvas.Top="10" Width="4" Height="4"
                                     Stroke="#680070" StrokeThickness="2" Fill="Transparent"/>
                            <Path Stroke="#680070" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M18,12 c0,1.7,-0.7,3.2,-1.8,4.2"/>
                        </Canvas>
                    </Viewbox>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Music Player" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="Developed by TranBNB" FontSize="11" FontStyle="Italic"
                                   Margin="1,2,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Column="0" Name="BtnShuffleAll" Click="BtnShuffleAll_Click"
                           Appearance="Primary" Height="38" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowShuffle20" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Shuffle all" FontWeight="SemiBold"/>
                    </StackPanel>
                </ui:Button>

                <ui:Button Grid.Column="2" Name="BtnShufflePlaylist" Click="BtnShufflePlaylist_Click"
                           IsEnabled="False" Appearance="Secondary" Height="38" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowShuffle20" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Shuffle playlist"/>
                    </StackPanel>
                </ui:Button>

                <TextBlock Grid.Column="4" Text="Playlist:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                <ComboBox Grid.Column="5" Name="PlaylistCombo" Width="220" Height="34"
                          Margin="8,0,0,0" HorizontalAlignment="Left"
                          VerticalContentAlignment="Center"
                          SelectionChanged="PlaylistCombo_SelectionChanged"/>

                <TextBlock Grid.Column="6" Name="TxtStatus" VerticalAlignment="Center"
                           FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Text="Ready"/>
            </Grid>

            <!-- Song List Card: Grid wrapper forces ListView to always fill the full card height -->
            <ui:Card Grid.Row="2" Padding="0">
                <Grid>
                    <ListView Name="SongsListView"
                              MouseDoubleClick="SongsListView_MouseDoubleClick"
                              BorderThickness="0"
                              Background="Transparent"
                              FontSize="14"
                              ItemContainerStyle="{StaticResource SongRowStyle}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="TRACK" Width="500">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"
                                                       Padding="16,0,8,0"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="PLAYLIST" Width="300">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Playlist}"
                                                       Padding="8,0"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </ui:Card>

            <!-- Player Bar Card -->
            <ui:Card Grid.Row="3" Margin="0,16,0,0" Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.5*"/>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="3.5*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Now Playing Info -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="NOW PLAYING" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                        <TextBlock Name="TxtCurrentTrack" Text="No track loaded"
                                   FontSize="20" FontWeight="SemiBold"
                                   Margin="0,6,12,0" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Name="TxtQueueInfo" Text="Queue: 0 / 0"
                                   FontSize="11" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Progress Slider -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="28,0">
                        <Slider Name="ProgressSlider"
                                Template="{StaticResource ProgressSliderTemplate}"
                                Minimum="0" Maximum="1" Value="0" IsEnabled="False"
                                Cursor="Hand"
                                ValueChanged="ProgressSlider_ValueChanged"
                                PreviewMouseLeftButtonDown="ProgressSlider_MouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="ProgressSlider_MouseLeftButtonUp"/>
                        <Grid Margin="2,8,2,0">
                            <TextBlock Name="TxtPosition" Text="00:00" FontSize="11"
                                       HorizontalAlignment="Left"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Name="TxtDuration" Text="/ 00:00" FontSize="11"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Playback Controls: Prev | PlayPause | Stop | Next | Loop -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <ui:Button Name="BtnPrevious" Click="BtnPrevious_Click"
                                   Style="{StaticResource PlayerCtrlBtn}" Width="44" Height="44" Padding="0"
                                   Margin="0,0,8,0" ToolTip="Previous / Restart" Cursor="Hand">
                            <Viewbox Width="20" Height="20" Stretch="Uniform">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="#680070" StrokeThickness="1.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" Fill="Transparent"
                                          Data="M17.971,4.285 A2,2,0,0,1,21,6 v12 a2,2,0,0,1,-3.029,1.715 l-9.997,-5.998 a2,2,0,0,1,-0.003,-3.432 Z"/>
                                    <Path Stroke="#680070" StrokeThickness="1.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M3,20 V4"/>
                                </Canvas>
                            </Viewbox>
                        </ui:Button>
                        <ui:Button Name="BtnPlayPause" Click="BtnPlayPause_Click"
                                   Appearance="Primary" Width="52" Height="52" Padding="0"
                                   Margin="0,0,8,0" ToolTip="Play / Pause" Cursor="Hand">
                            <ui:SymbolIcon x:Name="PlayPauseIcon" Symbol="Play20" FontSize="22"/>
                        </ui:Button>
                        <ui:Button Name="BtnNext" Click="BtnNext_Click"
                                   Style="{StaticResource PlayerCtrlBtn}" Width="44" Height="44" Padding="0"
                                   Margin="0,0,8,0" ToolTip="Next in queue" Cursor="Hand">
                            <Viewbox Width="20" Height="20" Stretch="Uniform">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="#680070" StrokeThickness="1.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M21,4 V20"/>
                                    <Path Stroke="#680070" StrokeThickness="1.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" Fill="Transparent"
                                          Data="M6.029,4.285 A2,2,0,0,0,3,6 v12 a2,2,0,0,0,3.029,1.715 l9.997,-5.998 a2,2,0,0,0,0.003,-3.432 Z"/>
                                </Canvas>
                            </Viewbox>
                        </ui:Button>
                        <ui:Button Name="BtnLoopOne" Click="BtnLoopOne_Click"
                                   Style="{StaticResource PlayerCtrlBtn}" Width="44" Height="44" Padding="0"
                                   ToolTip="Loop track" Cursor="Hand">
                            <ui:SymbolIcon Symbol="ArrowRepeat120" FontSize="20"/>
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </ui:Card>
        </Grid>
    </Grid>
</ui:FluentWindow>
