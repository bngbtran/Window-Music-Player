<Window x:Class="WindowMusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wpfui="WPF.UI"
        mc:Ignorable="d"
        Title="Window Music Player"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="White">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                <Button Name="BtnOpenFolder" Click="BtnOpenFolder_Click" Margin="0,0,8,0" Padding="10,8" wpfui:WPFUI.CornerRadius="12" wpfui:WPFUI.MouseOverBackground="#EDF4FF" wpfui:WPFUI.BorderBrush="#D0D7E5">Open Folder</Button>
                <Button Name="BtnShuffleAll" Click="BtnShuffleAll_Click" IsEnabled="False" Margin="0,0,8,0" Padding="10,8" wpfui:WPFUI.CornerRadius="12" wpfui:WPFUI.MouseOverBackground="#EDF4FF" wpfui:WPFUI.BorderBrush="#D0D7E5">Shuffle All</Button>
                <Button Name="BtnShufflePlaylist" Click="BtnShufflePlaylist_Click" IsEnabled="False" Margin="0,0,8,0" Padding="10,8" wpfui:WPFUI.CornerRadius="12" wpfui:WPFUI.MouseOverBackground="#EDF4FF" wpfui:WPFUI.BorderBrush="#D0D7E5">Shuffle Playlist</Button>
                <TextBlock VerticalAlignment="Center" Margin="14,0,6,0" FontSize="14" Foreground="#2B2B2B">Playlist:</TextBlock>
                <ComboBox Name="PlaylistCombo" Width="280" SelectionChanged="PlaylistCombo_SelectionChanged" />
            </StackPanel>

            <TextBlock Name="TxtStatus" DockPanel.Dock="Right" VerticalAlignment="Center" FontSize="14" Foreground="#2B2B2B" Text="Ready" />
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.3*" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <ListView Name="SongsListView" SelectionChanged="SongsListView_SelectionChanged" MouseDoubleClick="SongsListView_MouseDoubleClick" Margin="0,0,16,0" Background="White" BorderBrush="#E5E5E5" BorderThickness="1">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Track" DisplayMemberBinding="{Binding Name}" Width="420" />
                        <GridViewColumn Header="Playlist" DisplayMemberBinding="{Binding Playlist}" Width="260" />
                    </GridView>
                </ListView.View>
            </ListView>

            <Border Grid.Column="1" Background="#F8F8F8" BorderBrush="#E5E5E5" BorderThickness="1" Padding="18" CornerRadius="14">
                <StackPanel>
                    <TextBlock Text="Now Playing" FontWeight="Bold" FontSize="18" Margin="0,0,0,14" Foreground="#1D1D1D" />
                    <TextBlock Name="TxtCurrentTrack" Text="No track loaded" TextWrapping="Wrap" FontSize="16" Margin="0,0,0,16" Foreground="#424242" />

                    <TextBlock Text="Progress" FontWeight="SemiBold" Margin="0,0,0,6" FontSize="13" Foreground="#424242" />
                    <Slider Name="ProgressSlider" Minimum="0" Maximum="1" Value="0" IsEnabled="False" ValueChanged="ProgressSlider_ValueChanged" PreviewMouseLeftButtonDown="ProgressSlider_MouseLeftButtonDown" PreviewMouseLeftButtonUp="ProgressSlider_MouseLeftButtonUp" />
                    <DockPanel Margin="0,6,0,18">
                        <TextBlock Name="TxtPosition" Text="00:00" DockPanel.Dock="Left" FontSize="12" Foreground="#666" />
                        <TextBlock Name="TxtDuration" Text="/ 00:00" DockPanel.Dock="Right" HorizontalAlignment="Right" FontSize="12" Foreground="#666" />
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14">
                        <Button Name="BtnPlay" Click="BtnPlay_Click" Width="72" IsEnabled="False" Padding="10,8" wpfui:WPFUI.CornerRadius="12" wpfui:WPFUI.MouseOverBackground="#EDF4FF" wpfui:WPFUI.BorderBrush="#D0D7E5">▶</Button>
                        <Button Name="BtnPause" Click="BtnPause_Click" Width="72" Margin="0,0,8,0" IsEnabled="False" Padding="10,8" wpfui:WPFUI.CornerRadius="12" wpfui:WPFUI.MouseOverBackground="#EDF4FF" wpfui:WPFUI.BorderBrush="#D0D7E5">⏸</Button>
                        <Button Name="BtnStop" Click="BtnStop_Click" Width="72" Margin="0,0,8,0" IsEnabled="False" Padding="10,8" wpfui:WPFUI.CornerRadius="12" wpfui:WPFUI.MouseOverBackground="#EDF4FF" wpfui:WPFUI.BorderBrush="#D0D7E5">⏹</Button>
                        <Button Name="BtnNext" Click="BtnNext_Click" Width="72" Margin="0,0,8,0" IsEnabled="False" Padding="10,8" wpfui:WPFUI.CornerRadius="12" wpfui:WPFUI.MouseOverBackground="#EDF4FF" wpfui:WPFUI.BorderBrush="#D0D7E5">⏭</Button>
                        <Button Name="BtnLoopOne" Click="BtnLoopOne_Click" Width="72" IsEnabled="False" Padding="10,8" wpfui:WPFUI.CornerRadius="12" wpfui:WPFUI.MouseOverBackground="#EDF4FF" wpfui:WPFUI.BorderBrush="#D0D7E5">🔂</Button>
                    </StackPanel>

                    <TextBlock Name="TxtQueueInfo" Text="Queue: 0 / 0" Margin="0,0,0,16" HorizontalAlignment="Center" FontSize="13" Foreground="#666" />
                    <TextBlock Text="Supported formats: mp3, wav, wma, aac, m4a" FontStyle="Italic" FontSize="12" TextWrapping="Wrap" Foreground="#777" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Text="Double-click a song to play it. Drag the progress slider to seek." Margin="0,16,0,0" FontSize="13" Foreground="#666" />
    </Grid>
</Window>
